{
  "rewrites": [
    {
      "source": "/api/db/:table",
      "destination": "/api/db.js?table=:table"
    },
    {
      "source": "/api/files/:path*",
      "destination": "/api/files.js?path=:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
